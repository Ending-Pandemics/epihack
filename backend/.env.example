# ─── Application ───────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# ─── MongoDB ────────────────────────────────────────────────────
MONGO_USER=admin
MONGO_PASSWORD=secret
MONGODB_URL=mongodb://admin:secret@localhost:27017/epidemic_radar?authSource=admin
DB_NAME=epidemic_radar

# ─── CORS ───────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Alert Thresholds ───────────────────────────────────────────
ALERT_RESPONSE_THRESHOLD=10      # min responses to trigger scan
ALERT_ANOMALY_Z_SCORE=2.5        # z-score for anomaly flag
ALERT_SCAN_INTERVAL_MINUTES=15
